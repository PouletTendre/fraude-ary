{
  "colors": {
    "bg": "var(--bg)",
    "surface": "var(--surface)",
    "surface-raised": "var(--surface-raised)",
    "surface-sunken": "var(--surface-sunken)",
    "skeleton": "var(--skeleton)",
    "primary": {
      "DEFAULT": "#DA291C",
      "hover": "#B01E0A",
      "muted": "#9D2211",
      "subtle": "rgba(218,41,28,0.08)",
      "ring": "rgba(218,41,28,0.25)"
    },
    "accent-teal": {
      "DEFAULT": "#1EAEDB",
      "hover": "#1A9CC5"
    },
    "link-blue": "#3860BE",
    "yellow": "#FFF200",
    "yellow-modena": "#F6E500",
    "gain": {
      "DEFAULT": "#03904A",
      "muted": "rgba(3,144,74,0.12)"
    },
    "loss": {
      "DEFAULT": "#F13A2C",
      "muted": "rgba(241,58,44,0.12)"
    },
    "warning": {
      "DEFAULT": "#F13A2C",
      "muted": "rgba(241,58,44,0.12)"
    },
    "info": {
      "DEFAULT": "#4C98B9",
      "muted": "rgba(76,152,185,0.12)"
    },
    "text": {
      "primary": "var(--text-primary)",
      "secondary": "var(--text-secondary)",
      "tertiary": "var(--text-tertiary)",
      "muted": "var(--text-muted)",
      "disabled": "var(--text-disabled)"
    },
    "border": {
      "DEFAULT": "var(--border)",
      "hover": "var(--border-hover)"
    },
    "overlay": "hsla(0, 0%, 7%, 0.8)",
    "avatar": {
      "equity": {
        "bg": "rgba(218,41,28,0.12)",
        "border": "rgba(218,41,28,0.25)",
        "text": "#DA291C"
      },
      "crypto": {
        "bg": "rgba(76,152,185,0.12)",
        "border": "rgba(76,152,185,0.25)",
        "text": "#4C98B9"
      },
      "other": {
        "bg": "rgba(3,144,74,0.12)",
        "border": "rgba(3,144,74,0.25)",
        "text": "#03904A"
      }
    }
  },
  "fontFamily": {
    "sans": ["Inter", "Arial", "Helvetica", "sans-serif"],
    "body": ["Rajdhani", "Arial", "sans-serif"],
    "mono": ["JetBrains Mono", "ui-monospace", "monospace"]
  },
  "fontSize": {
    "display": ["1.625rem", { "lineHeight": "1.20", "letterSpacing": "normal", "fontWeight": "500" }],
    "h1": ["1.625rem", { "lineHeight": "1.20", "letterSpacing": "normal", "fontWeight": "500" }],
    "h2": ["1.50rem", { "lineHeight": "1.20", "fontWeight": "400" }],
    "h3": ["1.125rem", { "lineHeight": "1.20", "fontWeight": "700" }],
    "body": ["1rem", { "lineHeight": "1.40", "fontWeight": "400" }],
    "body-sm": ["0.875rem", { "lineHeight": "1.50", "fontWeight": "400" }],
    "button": ["1rem", { "lineHeight": "1", "letterSpacing": "1.28px", "fontWeight": "400" }],
    "label": ["0.75rem", { "lineHeight": "1.27", "letterSpacing": "1px", "fontWeight": "400" }],
    "micro-label": ["0.6875rem", { "lineHeight": "1.27", "letterSpacing": "1px", "fontWeight": "400" }],
    "nav-link": ["0.8125rem", { "lineHeight": "1.20", "letterSpacing": "0.13px", "fontWeight": "600" }],
    "mono-lg": ["1.375rem", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600" }],
    "section-label": ["0.6875rem", { "lineHeight": "1", "letterSpacing": "1px", "fontWeight": "500" }]
  },
  "borderRadius": {
    "none": "0px",
    "sm": "1px",
    "md": "2px",
    "lg": "2px",
    "xl": "8px",
    "full": "9999px"
  },
  "spacing": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "10px",
    "xl": "12px",
    "2xl": "14px",
    "3xl": "16px",
    "4xl": "18px",
    "5xl": "20px",
    "6xl": "24px",
    "7xl": "32px"
  },
  "boxShadow": {
    "md": "rgba(153, 153, 153, 0.12) 1px 1px 1px 0px",
    "lg": "rgba(153, 153, 153, 0.18) 1px 1px 1px 0px",
    "overlay": "rgba(153, 153, 153, 0.12) 1px 1px 1px 0px"
  }
}
